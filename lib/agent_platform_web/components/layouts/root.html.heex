<!DOCTYPE html>
<html lang="en" style="background: #0a0a0a;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title suffix=" | AgentPlatform">
      <%= assigns[:page_title] || "Dashboard" %>
    </.live_title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { background: #0a0a0a; }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #0a0a0a;
        color: #f5f5f5;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      /* Phoenix LiveView flash messages */
      .phx-flash { padding: 12px 20px; border-radius: 8px; margin: 12px 24px; font-size: 14px; }
      .phx-flash-info { background: rgba(6, 182, 212, 0.15); color: #06b6d4; border: 1px solid rgba(6, 182, 212, 0.3); }
      .phx-flash-error { background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); }
      /* LiveView connection states */
      .phx-connected { }
      .phx-loading { opacity: 0.6; transition: opacity 0.3s; }
      .phx-disconnected { opacity: 0.3; }
    </style>
    <script defer phx-track-static src="https://cdn.jsdelivr.net/npm/phoenix@1.7.14/priv/static/phoenix.min.js"></script>
    <script defer phx-track-static src="https://cdn.jsdelivr.net/npm/phoenix_live_view@0.20.17/priv/static/phoenix_live_view.min.js"></script>
    <script>
      // Initialize LiveView
      window.addEventListener("DOMContentLoaded", () => {
        if (typeof window.LiveView !== "undefined") return;
        let csrfToken = document.querySelector("meta[name='csrf-token']").getAttribute("content");
        let liveSocket = new window.LiveView.LiveSocket("/live", window.Phoenix.Socket, {
          params: { _csrf_token: csrfToken },
          longPollFallbackMs: 2500
        });
        liveSocket.connect();
        window.liveSocket = liveSocket;
      });
    </script>
  </head>
  <body>
    <%= @inner_content %>
  </body>
</html>
